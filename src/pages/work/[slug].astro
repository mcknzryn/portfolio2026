---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      previous: projects[(index - 1 + projects.length) % projects.length],
      next: projects[(index + 1) % projects.length],
    },
  }));
}

const { project, previous, next } = Astro.props;
const { Content } = await render(project);

const projectNumber = String(project.data.order + 1).padStart(2, '0');
const client = project.data.client || 'Independent';
---

<BaseLayout title={`${project.data.title} | Work`} bodyClass="work-case-page">
  <article class="case-study">
    <section class="case-main">
      <aside class="case-copy" aria-label={`${project.data.title} project details`}>
        <div class="case-copy-block">
          <p class="case-index">({projectNumber})</p>
          <h1 class="case-title">{project.data.title}</h1>
          <p class="case-disciplines">{project.data.discipline.join(', ')}</p>
          <p class="case-summary">{project.data.summary}</p>
          <div class="case-meta">
            <p>{client}</p>
            <p>{project.data.year}</p>
          </div>
        </div>

        <div class="case-copy-block">
          <p class="case-kicker">Notes</p>
          <p class="case-panel-copy">
            A quieter page for slower image reading, with the text held in a fixed left rail while the image sequence moves independently to the right.
          </p>
          <div class="case-notes">
            <Content />
          </div>
        </div>

        <div class="case-copy-block case-copy-block--meta">
          <p class="case-kicker">Selected frame</p>
          <div class="case-details">
            <p>
              <span class="case-detail-label">Client</span>
              <span>{client}</span>
            </p>
            <p>
              <span class="case-detail-label">Year</span>
              <span>{project.data.year}</span>
            </p>
            <p>
              <span class="case-detail-label">Discipline</span>
              <span>{project.data.discipline.join(', ')}</span>
            </p>
          </div>
        </div>
      </aside>

      <section class="case-images" aria-label={`${project.data.title} imagery`}>
        {project.data.images.map((image, index) => (
          <figure class:list={['case-figure', `case-figure--${image.layout}`, index === 0 && 'case-figure--first']}>
            <img src={image.src} alt={image.alt} loading={index === 0 ? 'eager' : 'lazy'} />
          </figure>
        ))}
      </section>
    </section>

    <footer class="case-footer" aria-label="Project navigation">
      <div class="case-footer-meta">
        <p class="case-kicker">{client}</p>
        <p class="case-footer-year">{project.data.year}</p>
      </div>

      <a class="case-footer-link case-footer-link--prev" href={`/work/${previous.id}`}>
        Previous project
      </a>

      <span class="case-footer-counter" aria-label={`Project ${projectNumber}`}>[{projectNumber}]</span>

      <a class="case-footer-link case-footer-link--next" href={`/work/${next.id}`}>
        Next project
      </a>
    </footer>
  </article>

  <script>
    let controller;

    const resetTrack = () => {
      const track = document.querySelector('.case-images');

      if (!track) return;

      track.scrollLeft = 0;
      track.scrollTop = 0;
    };

    const bindTrack = () => {
      controller?.abort();
      controller = new AbortController();

      const track = document.querySelector('.case-images');

      if (!track) return;

      const { signal } = controller;

      track.addEventListener(
        'wheel',
        (event) => {
          const hasHorizontalIntent = Math.abs(event.deltaX) > Math.abs(event.deltaY);

          if (hasHorizontalIntent) return;

          const maxScrollLeft = track.scrollWidth - track.clientWidth;
          const canScroll = maxScrollLeft > 0;
          const movingRight = event.deltaY > 0;
          const movingLeft = event.deltaY < 0;
          const atStart = track.scrollLeft <= 0;
          const atEnd = track.scrollLeft >= maxScrollLeft - 1;

          if (!canScroll || (movingLeft && atStart) || (movingRight && atEnd)) {
            return;
          }

          event.preventDefault();
          track.scrollLeft += event.deltaY;
        },
        { passive: false, signal },
      );
    };

    const scheduleReset = () => {
      requestAnimationFrame(() => requestAnimationFrame(resetTrack));
    };

    const setup = () => {
      bindTrack();
      scheduleReset();
    };

    document.addEventListener('astro:page-load', setup);
    window.addEventListener('pageshow', setup);
  </script>
</BaseLayout>

<style>
  .case-study {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
    min-height: 0;
  }

  .case-main {
    position: relative;
    display: grid;
    grid-template-columns: minmax(19rem, 0.36fr) minmax(0, 0.64fr);
    gap: clamp(1rem, 1.8vw, 1.8rem);
    height: 100%;
    min-height: 0;
  }

  .case-copy {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: clamp(1.2rem, 1.8vw, 2rem);
    padding: clamp(1rem, 1.4vw, 1.25rem) 0 clamp(1rem, 1.8vw, 1.6rem) var(--pad);
    overflow: auto;
    min-height: 0;
    background: transparent;
  }

  .case-copy-block {
    display: grid;
    gap: 0.8rem;
    max-width: 22rem;
  }

  .case-copy-block--meta {
    padding-top: 0.35rem;
    border-top: 0.5px solid var(--line);
  }

  .case-images {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    height: 100%;
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    scroll-behavior: auto;
    scroll-padding-inline: 0;
    scrollbar-width: none;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
  }

  .case-images::-webkit-scrollbar {
    display: none;
  }

  .case-figure {
    flex: 0 0 100%;
    min-width: 100%;
    height: 100%;
    margin: 0;
    padding: clamp(1rem, 1.4vw, 1.25rem) var(--pad) clamp(1rem, 1.8vw, 1.6rem);
    scroll-snap-align: start;
  }

  .case-index {
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1;
  }

  .case-title {
    margin: 0;
    max-width: 9ch;
    font-family: var(--grotesk);
    font-size: clamp(3.1rem, 6.3vw, 6.1rem);
    font-weight: 700;
    letter-spacing: -0.085em;
    line-height: 0.82;
    text-transform: uppercase;
  }

  .case-disciplines {
    margin: 0;
    max-width: 20ch;
    font-size: clamp(0.82rem, 0.9vw, 0.92rem);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .case-summary,
  .case-panel-copy,
  .case-notes :global(p) {
    margin: 0;
    max-width: 24rem;
    color: #afafaf;
    font-size: clamp(0.92rem, 1.02vw, 1.08rem);
    line-height: 1.26;
  }

  .case-meta {
    display: grid;
    gap: 0.2rem;
    margin-top: clamp(0.6rem, 1vw, 1rem);
  }

  .case-meta p,
  .case-details p {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    color: var(--muted);
    font-size: clamp(0.7rem, 0.78vw, 0.82rem);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .case-detail-label {
    color: var(--ink);
  }

  .case-notes {
    display: grid;
    gap: 1rem;
    max-width: 22rem;
  }

  .case-details {
    display: grid;
    gap: 0.45rem;
    padding-top: 0.35rem;
    border-top: 0.5px solid var(--line);
  }

  .case-figure img {
    width: 100%;
    height: 100%;
    max-height: calc(100dvh - 7rem);
    object-fit: cover;
    border: 0.5px solid var(--line);
    background: #f4f4f4;
  }

  .case-figure--first {
    padding-left: var(--pad);
  }

  .case-figure--full img {
    object-fit: cover;
  }

  .case-figure--wide img {
    object-fit: cover;
  }

  .case-figure--narrow img {
    object-fit: contain;
    background: #f7f7f7;
  }

  .case-footer {
    display: grid;
    grid-template-columns: minmax(10rem, 0.95fr) minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: end;
    gap: 0.85rem;
    padding: 0.6rem var(--pad) 0.9rem;
    border-top: 0.5px solid var(--line);
  }

  .case-footer-meta {
    display: grid;
    gap: 0.1rem;
  }

  .case-footer-year {
    margin: 0;
    color: var(--muted);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .case-footer-link {
    align-self: center;
    color: var(--ink);
    font-size: clamp(0.92rem, 1.02vw, 1.06rem);
    font-weight: 700;
    text-decoration: none;
  }

  .case-footer-link--prev {
    justify-self: center;
  }

  .case-footer-link--next {
    justify-self: end;
  }

  .case-footer-counter {
    color: var(--muted);
    font-size: clamp(0.72rem, 0.8vw, 0.84rem);
    justify-self: center;
  }

  @media (hover: hover) {
    .case-footer-link:hover {
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }

    .case-figure img {
      transition: transform 320ms ease, box-shadow 320ms ease;
    }

    .case-figure:hover img {
      transform: scale(1.01);
    }
  }

  @media (max-width: 980px) {
    .case-main {
      grid-template-columns: 1fr;
    }

    .case-copy {
      padding-right: var(--pad);
      background: transparent;
    }

    .case-images {
      position: relative;
      min-height: 34rem;
      order: 2;
      border-top: 0.5px solid var(--line);
    }

    .case-figure img {
      height: auto;
      min-height: 28rem;
      max-height: none;
      aspect-ratio: 16 / 10;
    }

    .case-footer {
      grid-template-columns: 1fr auto;
      row-gap: 0.5rem;
    }

    .case-footer-link--prev {
      justify-self: start;
    }

    .case-footer-link--next {
      justify-self: end;
    }

    .case-footer-counter {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .case-copy {
      padding-top: 0.85rem;
      gap: 1rem;
    }

    .case-title {
      font-size: clamp(2.8rem, 15vw, 5rem);
    }

    .case-images {
      min-height: 24rem;
    }
  }
</style>
