---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      previous: projects[(index - 1 + projects.length) % projects.length],
      next: projects[(index + 1) % projects.length],
    },
  }));
}

const { project, previous, next } = Astro.props;

const projectNumber = String(project.data.order + 1).padStart(2, '0');
const client = project.data.client || 'Independent';
const gallery = project.data.gallery || {};
const galleryStyle = [
  gallery.trackGap ? `--case-track-gap: ${gallery.trackGap};` : '',
  gallery.trackInset ? `--case-track-inset: ${gallery.trackInset};` : '',
  gallery.trackEnd ? `--case-track-end: ${gallery.trackEnd};` : '',
]
  .filter(Boolean)
  .join(' ');

const getImageStyle = (image) => {
  const imageWidth = image.width || gallery.imageWidths?.[image.layout];
  const offsetY = image.offsetY;

  return [
    imageWidth ? `--case-figure-width: ${imageWidth};` : '',
    offsetY ? `--case-figure-offset-y: ${offsetY};` : '',
  ]
    .filter(Boolean)
    .join(' ');
};
---

<BaseLayout title={`${project.data.title} | Work`} bodyClass="work-case-page">
  <article class="case-study">
    <section class="case-main" style={galleryStyle}>
      <aside class="case-copy" aria-label={`${project.data.title} project details`}>
        <div class="case-copy-block">
          <p class="case-index">Order {projectNumber}</p>
          <h1 class="case-title">{project.data.title}</h1>
          <div class="case-details">
            <p>
              <span class="case-detail-label">Discipline</span>
              <span>{project.data.discipline.join(', ')}</span>
            </p>
            <p>
              <span class="case-detail-label">Year</span>
              <span>{project.data.year}</span>
            </p>
            <p>
              <span class="case-detail-label">Client</span>
              <span>{client}</span>
            </p>
          </div>
          <p class="case-summary">{project.data.summary}</p>
        </div>
      </aside>

      <section class="case-images" aria-label={`${project.data.title} imagery`}>
        {project.data.images.map((image, index) => (
          <figure class:list={['case-figure', `case-figure--${image.layout}`]} style={getImageStyle(image)}>
            <img src={image.src} alt={image.alt} loading={index === 0 ? 'eager' : 'lazy'} />
          </figure>
        ))}
      </section>

      <div class="case-progress" aria-hidden="true">
        <span class="case-progress-track"></span>
        <span class="case-progress-thumb"></span>
      </div>
    </section>

    <footer class="case-footer" aria-label="Project navigation">
      <a class="case-footer-link case-footer-link--prev" href={`/work/${previous.id}`}>
        Previous project
      </a>

      <span class="case-footer-counter" aria-label={`Project ${projectNumber}`}>[{projectNumber}]</span>

      <a class="case-footer-link case-footer-link--next" href={`/work/${next.id}`}>
        Next project
      </a>
    </footer>
  </article>

  <script>
    let controller;
    let observer;
    let rafId;
    let progressRafId;
    let dragState;
    let scrollTarget = 0;

    const updateTrackOffset = () => {
      const main = document.querySelector('.case-main');
      const copy = document.querySelector('.case-copy');

      if (!main || !copy) return;

      const styles = getComputedStyle(main);
      const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
      const inset = parseFloat(styles.getPropertyValue('--case-track-inset')) || 0;
      const offset = Math.max(0, copy.getBoundingClientRect().width + gap - inset);

      main.style.setProperty('--case-track-offset', `${offset}px`);
    };

    const getProgressMetrics = () => {
      const track = document.querySelector('.case-images');
      const rail = document.querySelector('.case-progress');

      if (!track || !rail) return null;

      const maxScrollLeft = Math.max(0, track.scrollWidth - track.clientWidth);
      const railHeight = rail.clientHeight;
      const thumbHeight = Math.max(36, railHeight * (track.clientWidth / Math.max(track.scrollWidth, 1)));
      const travel = Math.max(0, railHeight - thumbHeight);

      return { track, railHeight, maxScrollLeft, thumbHeight, travel };
    };

    const updateProgress = (progress) => {
      const thumb = document.querySelector('.case-progress-thumb');
      const metrics = getProgressMetrics();

      if (!thumb || !metrics) return;

      const clamped = Math.min(1, Math.max(0, progress));
      const top = metrics.travel * clamped;

      thumb.style.height = `${metrics.thumbHeight}px`;
      thumb.style.transform = `translateY(${top}px)`;
    };

    const syncProgress = () => {
      const track = document.querySelector('.case-images');

      if (!track) return;

      const maxScrollLeft = track.scrollWidth - track.clientWidth;
      const progress = maxScrollLeft > 0 ? track.scrollLeft / maxScrollLeft : 0;

      updateProgress(progress);
      progressRafId = undefined;
    };

    const resetTrack = () => {
      const track = document.querySelector('.case-images');

      if (!track) return;

      if (rafId != null) {
        cancelAnimationFrame(rafId);
        rafId = undefined;
      }

      if (progressRafId != null) {
        cancelAnimationFrame(progressRafId);
        progressRafId = undefined;
      }

      track.scrollLeft = 0;
      track.scrollTop = 0;
      scrollTarget = 0;
      updateProgress(0);
    };

    const scrollToProgress = (progress) => {
      const track = document.querySelector('.case-images');
      const metrics = getProgressMetrics();

      if (!track || !metrics) return;

      const clamped = Math.min(1, Math.max(0, progress));
      scrollTarget = metrics.maxScrollLeft * clamped;
      track.scrollLeft = scrollTarget;
      updateProgress(clamped);
    };

    const animateScroll = () => {
      const track = document.querySelector('.case-images');

      if (!track) return;

      const current = track.scrollLeft;
      const delta = scrollTarget - current;

      if (Math.abs(delta) < 0.35) {
        track.scrollLeft = scrollTarget;
        rafId = undefined;
        return;
      }

      track.scrollLeft = current + delta * 0.14;
      rafId = requestAnimationFrame(animateScroll);
    };

    const bindTrack = () => {
      controller?.abort();
      controller = new AbortController();

      const track = document.querySelector('.case-images');
      const main = document.querySelector('.case-main');
      const thumb = document.querySelector('.case-progress-thumb');
      const rail = document.querySelector('.case-progress');

      if (!track) return;

      if (rafId != null) {
        cancelAnimationFrame(rafId);
        rafId = undefined;
      }

      if (progressRafId != null) {
        cancelAnimationFrame(progressRafId);
        progressRafId = undefined;
      }

      const { signal } = controller;

      track.addEventListener(
        'wheel',
        (event) => {
          const hasHorizontalIntent = Math.abs(event.deltaX) > Math.abs(event.deltaY);

          if (hasHorizontalIntent) {
            return;
          }

          const maxScrollLeft = track.scrollWidth - track.clientWidth;
          const canScroll = maxScrollLeft > 0;
          if (!canScroll) return;

          event.preventDefault();

          const direction = event.deltaY !== 0 ? event.deltaY : event.deltaX;
          const nextTarget = scrollTarget + direction * 0.9;

          scrollTarget = Math.min(maxScrollLeft, Math.max(0, nextTarget));

          if (rafId == null) {
            rafId = requestAnimationFrame(animateScroll);
          }

          if (progressRafId == null) {
            progressRafId = requestAnimationFrame(syncProgress);
          }
        },
        { passive: false, signal },
      );

      track.addEventListener(
        'scroll',
        () => {
          if (progressRafId != null) return;

          progressRafId = requestAnimationFrame(syncProgress);
        },
        { signal },
      );

      thumb?.addEventListener(
        'pointerdown',
        (event) => {
          const metrics = getProgressMetrics();

          if (!metrics) return;

          event.preventDefault();
          thumb.setPointerCapture(event.pointerId);
          main?.classList.add('is-dragging');

          dragState = {
            pointerId: event.pointerId,
            startY: event.clientY,
            startProgress: metrics.maxScrollLeft > 0 ? track.scrollLeft / metrics.maxScrollLeft : 0,
          };
        },
        { signal },
      );

      rail?.addEventListener(
        'pointerdown',
        (event) => {
          if (event.target === thumb) return;

          const metrics = getProgressMetrics();
          if (!metrics) return;

          const rect = rail.getBoundingClientRect();
          const localY = event.clientY - rect.top;
          const progress = metrics.travel > 0 ? (localY - metrics.thumbHeight / 2) / metrics.travel : 0;

          event.preventDefault();
          scrollToProgress(progress);
        },
        { signal },
      );

      const handlePointerMove = (event) => {
        if (!dragState || event.pointerId !== dragState.pointerId) return;

        const metrics = getProgressMetrics();
        if (!metrics) return;

        const deltaY = event.clientY - dragState.startY;
        const progressDelta = metrics.travel > 0 ? deltaY / metrics.travel : 0;

        scrollToProgress(dragState.startProgress + progressDelta);
      };

      const handlePointerUp = (event) => {
        if (!dragState || event.pointerId !== dragState.pointerId) return;

        if (thumb?.hasPointerCapture(event.pointerId)) {
          thumb.releasePointerCapture(event.pointerId);
        }

        main?.classList.remove('is-dragging');
        dragState = undefined;
      };

      window.addEventListener('pointermove', handlePointerMove, { signal });
      window.addEventListener('pointerup', handlePointerUp, { signal });
      window.addEventListener('pointercancel', handlePointerUp, { signal });
    };

    const scheduleReset = () => {
      requestAnimationFrame(() => requestAnimationFrame(resetTrack));
    };

    const setup = () => {
      bindTrack();
      observer?.disconnect();
      observer = new ResizeObserver(() => {
        updateTrackOffset();
        syncProgress();
      });
      const main = document.querySelector('.case-main');

      if (main) {
        observer.observe(main);
      }

      updateTrackOffset();
      const track = document.querySelector('.case-images');

      if (track) {
        scrollTarget = track.scrollLeft;
      }
      syncProgress();
      scheduleReset();
    };

    document.addEventListener('astro:page-load', setup);
    window.addEventListener('pageshow', setup);
  </script>
</BaseLayout>

<style>
  .case-study {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
    min-height: 0;
  }

  .case-main {
    position: relative;
    display: grid;
    grid-template-columns: minmax(19rem, 0.36fr) minmax(0, 0.64fr);
    gap: clamp(1rem, 1.8vw, 1.8rem);
    height: 100%;
    min-height: 0;
    --case-track-gap: clamp(3rem, 4.8vw, 5.75rem);
    --case-track-inset: clamp(1rem, 1.4vw, 1.8rem);
    --case-track-end: clamp(5rem, 8vw, 9rem);
  }

  .case-copy {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: clamp(1.2rem, 1.8vw, 2rem);
    padding: clamp(1rem, 1.4vw, 1.25rem) 0 clamp(1rem, 1.8vw, 1.6rem) var(--pad);
    min-height: 0;
    background: transparent;
  }

  .case-copy-block {
    display: grid;
    gap: 0.8rem;
    max-width: 22rem;
  }

  .case-images {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: flex-start;
    gap: var(--case-track-gap, clamp(3rem, 4.8vw, 5.75rem));
    height: 100%;
    min-width: 0;
    padding-left: var(--case-track-offset, 0px);
    padding-right: var(--case-track-end, clamp(5rem, 8vw, 9rem));
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: none;
    scroll-behavior: auto;
    scroll-padding-inline-start: var(--case-track-offset, 0px);
    scrollbar-width: none;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
  }

  .case-images::-webkit-scrollbar {
    display: none;
  }

  .case-progress {
    position: absolute;
    top: clamp(1rem, 1.4vw, 1.25rem);
    right: var(--pad);
    bottom: clamp(1rem, 1.8vw, 1.6rem);
    width: 0.22rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--line) 30%, transparent);
    pointer-events: auto;
    z-index: 2;
    user-select: none;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .case-progress-track {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: color-mix(in srgb, var(--line) 22%, transparent);
    opacity: 0.65;
  }

  .case-progress-thumb {
    position: absolute;
    left: 0;
    top: 0;
    display: block;
    width: 100%;
    border-radius: inherit;
    background: color-mix(in srgb, var(--ink) 24%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--ink) 8%, transparent) inset;
    pointer-events: auto;
    cursor: grab;
    touch-action: none;
    will-change: transform, height;
  }

  .case-progress-thumb:active {
    cursor: grabbing;
  }

  @media (hover: hover) {
    .case-main:hover .case-progress,
    .case-main.is-dragging .case-progress {
      opacity: 1;
    }
  }

  .case-figure {
    flex: 0 0 auto;
    width: auto;
    min-width: 0;
    height: auto;
    margin: 0;
    padding: clamp(0.45rem, 0.75vw, 0.85rem) 0 clamp(0.45rem, 0.95vw, 0.95rem);
    width: var(--case-figure-width, auto);
    margin-top: var(--case-figure-offset-y, 0);
  }

  .case-index {
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1;
  }

  .case-title {
    margin: 0;
    max-width: 9ch;
    font-family: var(--grotesk);
    font-size: clamp(3.1rem, 6.3vw, 6.1rem);
    font-weight: 700;
    letter-spacing: -0.085em;
    line-height: 0.82;
    text-transform: uppercase;
  }

  .case-summary {
    margin: 0;
    max-width: 24rem;
    color: #afafaf;
    font-size: clamp(0.92rem, 1.02vw, 1.08rem);
    line-height: 1.26;
  }

  .case-details p {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    color: var(--muted);
    font-size: clamp(0.7rem, 0.78vw, 0.82rem);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .case-detail-label {
    color: var(--ink);
  }

  .case-figure img {
    display: block;
    width: 100%;
    height: auto;
    max-width: none;
    max-height: calc(100dvh - 7rem);
    object-fit: contain;
    border: 0;
    background: transparent;
  }

  .case-figure--full img {
    max-width: none;
  }

  .case-figure--wide img {
    max-width: none;
  }

  .case-figure--narrow img {
    max-width: none;
    background: transparent;
  }

  .case-footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: end;
    gap: 0.85rem;
    padding: 0.6rem var(--pad) 0.9rem;
    border-top: 0.5px solid var(--line);
  }

  .case-footer-link {
    align-self: center;
    color: var(--ink);
    font-size: clamp(0.92rem, 1.02vw, 1.06rem);
    font-weight: 700;
    text-decoration: none;
  }

  .case-footer-link--prev {
    justify-self: center;
  }

  .case-footer-link--next {
    justify-self: end;
  }

  .case-footer-counter {
    color: var(--muted);
    font-size: clamp(0.72rem, 0.8vw, 0.84rem);
    justify-self: center;
  }

  @media (hover: hover) {
    .case-footer-link:hover {
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }
  }

  @media (max-width: 980px) {
    .case-main {
      grid-template-columns: 1fr;
    }

    .case-copy {
      padding-right: var(--pad);
      background: transparent;
    }

    .case-images {
      position: relative;
      min-height: 34rem;
      order: 2;
      padding-left: 0;
      padding-right: var(--case-track-end, clamp(5rem, 8vw, 9rem));
      border-top: 0.5px solid var(--line);
      scroll-padding-inline-start: 0;
    }

    .case-progress {
      display: none;
    }

    .case-figure img {
      max-height: calc(100dvh - 9rem);
    }

    .case-figure {
      width: var(--case-figure-width, min(88vw, 72rem));
    }

    .case-figure img {
      width: 100%;
    }

    .case-footer {
      grid-template-columns: 1fr auto;
      row-gap: 0.5rem;
    }

    .case-footer-link--prev {
      justify-self: start;
    }

    .case-footer-link--next {
      justify-self: end;
    }

    .case-footer-counter {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .case-copy {
      padding-top: 0.85rem;
      gap: 1rem;
    }

    .case-title {
      font-size: clamp(2.8rem, 15vw, 5rem);
    }

    .case-images {
      min-height: 24rem;
    }
  }
</style>
