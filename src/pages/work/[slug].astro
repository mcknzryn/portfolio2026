---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      previous: projects[(index - 1 + projects.length) % projects.length],
      next: projects[(index + 1) % projects.length],
    },
  }));
}

type ProjectEntry = CollectionEntry<'projects'>;
type ProjectImage = ProjectEntry['data']['images'][number];

const { project, previous, next }: { project: ProjectEntry; previous: ProjectEntry; next: ProjectEntry } = Astro.props;

const projectNumber = String(project.data.order + 1).padStart(2, '0');
const client = project.data.client || 'Independent';
const gallery = project.data.gallery || {};
const galleryStyle = [
  gallery.trackGap ? `--case-track-gap: ${gallery.trackGap};` : '',
  gallery.trackInset ? `--case-track-inset: ${gallery.trackInset};` : '',
  gallery.trackEnd ? `--case-track-end: ${gallery.trackEnd};` : '',
]
  .filter(Boolean)
  .join(' ');

const getImageStyle = (image: ProjectImage) => {
  const imageWidth = image.width || gallery.imageWidths?.[image.layout];
  const offsetY = image.offsetY;

  return [
    imageWidth ? `--case-figure-width: ${imageWidth};` : '',
    offsetY ? `--case-figure-offset-y: ${offsetY};` : '',
  ]
    .filter(Boolean)
    .join(' ');
};
---

<BaseLayout title={`${project.data.title} | Work`} bodyClass="work-case-page">
  <article class="case-study">
    <section class="case-main" style={galleryStyle}>
      <aside class="case-copy" aria-label={`${project.data.title} project details`}>
        <div class="case-copy-block">
          <p class="case-index"> [{projectNumber}]</p>
          <h1 class="case-title">{project.data.title}</h1>
          <div class="case-details">
            <p>
              <span>{project.data.discipline.join(', ')}</span>
            </p>
            <p>
              <span>{project.data.year}</span>
            </p>
            <p>
              <span>{client}</span>
            </p>
          </div>
          <p class="case-summary">{project.data.summary}</p>
        </div>
      </aside>

      <section class="case-images" aria-label={`${project.data.title} imagery`}>
        {project.data.images.map((image, index) => (
          <figure class:list={['case-figure', `case-figure--${image.layout}`]} style={getImageStyle(image)}>
            <img src={image.src} alt={image.alt} loading={index === 0 ? 'eager' : 'lazy'} />
          </figure>
        ))}
      </section>

    </section>

    <footer class="case-footer" aria-label="Project navigation">
      <a class="case-footer-link case-footer-link--prev" href={`/work/${previous.id}`}>
        Previous project
      </a>

      <span class="case-footer-counter" aria-label={`Project ${projectNumber}`}>[{projectNumber}]</span>

      <a class="case-footer-link case-footer-link--next" href={`/work/${next.id}`}>
        Next project
      </a>
    </footer>
  </article>

  <script>
    let controller: AbortController | undefined;
    let observer: ResizeObserver | undefined;
    let rafId: number | undefined;
    let scrollTarget = 0;
    let scrollPosition = 0;
    let lastFrameTime = 0;
    let cleanup: () => void = () => {};

    const updateTrackOffset = () => {
      const main = document.querySelector<HTMLElement>('.case-main');
      const copy = document.querySelector<HTMLElement>('.case-copy');

      if (!main || !copy) return;

      const styles = getComputedStyle(main);
      const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
      const inset = parseFloat(styles.getPropertyValue('--case-track-inset')) || 0;
      const offset = Math.max(0, copy.getBoundingClientRect().width + gap - inset);

      main.style.setProperty('--case-track-offset', `${offset}px`);
    };

    const animateScroll = () => {
      const track = document.querySelector<HTMLElement>('.case-images');

      if (!track) return;

      const now = performance.now();
      const elapsed = lastFrameTime ? Math.min(32, now - lastFrameTime) : 16;
      lastFrameTime = now;
      const delta = scrollTarget - scrollPosition;
      const distance = Math.abs(delta);

      if (distance < 0.35) {
        scrollPosition = scrollTarget;
        track.scrollLeft = scrollTarget;
        rafId = undefined;
        return;
      }

      const easing = 1 - Math.pow(0.001, elapsed / 16);
      scrollPosition += delta * easing;
      track.scrollLeft = scrollPosition;
      rafId = requestAnimationFrame(animateScroll);
    };

    const bindTrack = () => {
      controller?.abort();
      controller = new AbortController();

      const track = document.querySelector<HTMLElement>('.case-images');

      if (!track) return;

      if (rafId != null) {
        cancelAnimationFrame(rafId);
        rafId = undefined;
      }

      const { signal } = controller;
      scrollPosition = track.scrollLeft;
      scrollTarget = track.scrollLeft;
      lastFrameTime = 0;

      const normalizeWheelDelta = (event: WheelEvent) => {
        const baseDelta = Math.abs(event.deltaY) > Math.abs(event.deltaX) ? event.deltaY : event.deltaX;

        if (event.deltaMode === WheelEvent.DOM_DELTA_LINE) {
          return baseDelta * 16;
        }

        if (event.deltaMode === WheelEvent.DOM_DELTA_PAGE) {
          return baseDelta * window.innerHeight;
        }

        return baseDelta;
      };

      window.addEventListener(
        'wheel',
        (event) => {
          const hasHorizontalIntent = Math.abs(event.deltaX) > Math.abs(event.deltaY);

          if (hasHorizontalIntent) {
            return;
          }

          const maxScrollLeft = track.scrollWidth - track.clientWidth;
          const canScroll = maxScrollLeft > 0;
          if (!canScroll) return;

          event.preventDefault();

          const direction = normalizeWheelDelta(event);
          const nextTarget = scrollTarget + direction * 0.65;

          scrollTarget = Math.min(maxScrollLeft, Math.max(0, nextTarget));

          if (rafId == null) {
            rafId = requestAnimationFrame(animateScroll);
          }
        },
        { passive: false, signal },
      );

      track.addEventListener(
        'scroll',
        () => {
          scrollTarget = track.scrollLeft;
        },
        { signal },
      );
    };

    const teardown = () => {
      cleanup();
      cleanup = () => {};
    };

    const setup = () => {
      teardown();

      bindTrack();

      observer?.disconnect();
      observer = new ResizeObserver(() => updateTrackOffset());
      const main = document.querySelector<HTMLElement>('.case-main');

      if (main) {
        observer.observe(main);
      }

      updateTrackOffset();
      const track = document.querySelector<HTMLElement>('.case-images');

      if (track) {
        scrollTarget = track.scrollLeft;
        scrollPosition = track.scrollLeft;
      }

      cleanup = () => {
        controller?.abort();
        observer?.disconnect();

        if (rafId != null) {
          cancelAnimationFrame(rafId);
          rafId = undefined;
        }
      };
    };

    document.addEventListener('astro:page-load', setup);
    window.addEventListener('pageshow', (event) => {
      if (event.persisted) {
        setup();
      }
    });
    document.addEventListener('astro:before-swap', teardown);
  </script>
</BaseLayout>

<style>
  .case-study {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
    min-height: 0;
  }

  .case-main {
    position: relative;
    display: grid;
    grid-template-columns: minmax(19rem, 0.36fr) minmax(0, 0.64fr);
    gap: clamp(1rem, 1.8vw, 1.8rem);
    height: 100%;
    min-height: 0;
    --case-track-gap: clamp(3rem, 4.8vw, 5.75rem);
    --case-track-inset: clamp(1rem, 1.4vw, 1.8rem);
    --case-track-end: clamp(5rem, 8vw, 9rem);
  }

  .case-copy {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: start;
    gap: clamp(1.2rem, 1.8vw, 2rem);
    padding: clamp(1rem, 1.4vw, 1.25rem) 0 clamp(1rem, 1.8vw, 1.6rem) var(--pad);
    min-height: 0;
    background: transparent;
  }

  .case-copy-block {
    display: grid;
    gap: 0.8rem;
    max-width: 22rem;
  }

  .case-images {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: flex-start;
    gap: var(--case-track-gap, clamp(3rem, 4.8vw, 5.75rem));
    height: 100%;
    min-width: 0;
    padding-left: var(--case-track-offset, 0px);
    padding-right: var(--case-track-end, clamp(5rem, 8vw, 9rem));
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: none;
    scroll-behavior: auto;
    scroll-padding-inline-start: var(--case-track-offset, 0px);
    scrollbar-width: none;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
  }

  .case-images::-webkit-scrollbar {
    display: none;
  }

  .case-figure {
    flex: 0 0 auto;
    width: auto;
    min-width: 0;
    height: auto;
    margin: 0;
    padding: clamp(0.45rem, 0.75vw, 0.85rem) 0 clamp(0.45rem, 0.95vw, 0.95rem);
    width: var(--case-figure-width, auto);
    margin-top: var(--case-figure-offset-y, 0);
  }

  .case-index {
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1;
  }

  .case-title {
    margin: 0;
    max-width: 9ch;
    font-family: var(--grotesk);
    font-size: clamp(3.1rem, 6.3vw, 6.1rem);
    font-weight: 700;
    letter-spacing: -0.085em;
    line-height: 0.82;
    text-transform: uppercase;
  }

  .case-summary {
    margin: 0;
    max-width: 24rem;
    color: #afafaf;
    font-size: clamp(0.92rem, 1.02vw, 1.08rem);
    line-height: 1.26;
  }

  .case-details p {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    color: var(--muted);
    font-size: clamp(0.7rem, 0.78vw, 0.82rem);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .case-detail-label {
    color: var(--ink);
  }

  .case-figure img {
    display: block;
    width: 100%;
    height: auto;
    max-width: none;
    max-height: calc(100dvh - 7rem);
    object-fit: contain;
    border: 0;
    background: transparent;
  }

  .case-figure--full img {
    max-width: none;
  }

  .case-figure--wide img {
    max-width: none;
  }

  .case-figure--narrow img {
    max-width: none;
    background: transparent;
  }

  .case-footer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: end;
    gap: 0.85rem;
    padding: 0.6rem var(--pad) 0.9rem;
    border-top: 0.5px solid var(--line);
  }

  .case-footer-link {
    align-self: center;
    color: var(--ink);
    font-size: clamp(0.92rem, 1.02vw, 1.06rem);
    font-weight: 700;
    text-decoration: none;
  }

  .case-footer-link--prev {
    justify-self: center;
  }

  .case-footer-link--next {
    justify-self: end;
  }

  .case-footer-counter {
    color: var(--muted);
    font-size: clamp(0.72rem, 0.8vw, 0.84rem);
    justify-self: center;
  }

  @media (hover: hover) {
    .case-footer-link:hover {
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }
  }

  @media (max-width: 980px) {
    .case-main {
      grid-template-columns: 1fr;
    }

    .case-copy {
      padding-right: var(--pad);
      background: transparent;
    }

    .case-images {
      position: relative;
      min-height: 34rem;
      order: 2;
      padding-left: 0;
      padding-right: var(--case-track-end, clamp(5rem, 8vw, 9rem));
      border-top: 0.5px solid var(--line);
      scroll-padding-inline-start: 0;
    }

    .case-figure img {
      max-height: calc(100dvh - 9rem);
    }

    .case-figure {
      width: var(--case-figure-width, min(88vw, 72rem));
    }

    .case-figure img {
      width: 100%;
    }

    .case-footer {
      grid-template-columns: 1fr auto;
      row-gap: 0.5rem;
    }

    .case-footer-link--prev {
      justify-self: start;
    }

    .case-footer-link--next {
      justify-self: end;
    }

    .case-footer-counter {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .case-copy {
      padding-top: 0.85rem;
      gap: 1rem;
    }

    .case-title {
      font-size: clamp(2.8rem, 15vw, 5rem);
    }

    .case-images {
      min-height: 24rem;
    }
  }
</style>
