---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      previous: projects[(index - 1 + projects.length) % projects.length],
      next: projects[(index + 1) % projects.length],
    },
  }));
}

const { project, previous, next } = Astro.props;
const { Content } = await render(project);

const projectNumber = String(project.data.order + 1).padStart(2, '0');
const client = project.data.client || 'Independent';
const hero = project.data.images[0];
const detail = project.data.images[1];
const system = project.data.images[2];
---

<BaseLayout title={`${project.data.title} | Work`} bodyClass="work-case-page">
  <article class="case-study">
    <section class="case-track" aria-label={`${project.data.title} case study`}>
      <section class="case-panel case-panel--intro">
        <div class="case-copy">
          <p class="case-index">({projectNumber})</p>
          <h1 class="case-title">{project.data.title}</h1>
          <p class="case-disciplines">{project.data.discipline.join(', ')}</p>
          <p class="case-summary">{project.data.summary}</p>
          <div class="case-meta">
            <p>{client}</p>
            <p>{project.data.year}</p>
          </div>
        </div>

        {hero && (
          <figure class="case-figure case-figure--hero">
            <img src={hero.src} alt={hero.alt} loading="eager" />
          </figure>
        )}
      </section>

      <section class="case-panel case-panel--notes">
        <div class="case-panel-heading">
          <p class="case-kicker">Notes</p>
          <p class="case-panel-copy">
            A quieter page for slower image reading, with the text and image field broken into lateral spreads rather than a long vertical stack.
          </p>
        </div>

        <div class="case-notes">
          <Content />
        </div>

        {detail && (
          <figure class="case-figure case-figure--detail">
            <img src={detail.src} alt={detail.alt} loading="lazy" />
          </figure>
        )}
      </section>

      <section class="case-panel case-panel--system">
        <div class="case-system-copy">
          <p class="case-kicker">Selected frame</p>
          <p class="case-panel-copy">
            The final panel gives the page room to breathe, letting the sequence end on a single image and a clean block of metadata instead of forcing a vertical collapse.
          </p>
          <div class="case-details">
            <p>
              <span class="case-detail-label">Client</span>
              <span>{client}</span>
            </p>
            <p>
              <span class="case-detail-label">Year</span>
              <span>{project.data.year}</span>
            </p>
            <p>
              <span class="case-detail-label">Discipline</span>
              <span>{project.data.discipline.join(', ')}</span>
            </p>
          </div>
        </div>

        {system && (
          <figure class="case-figure case-figure--system">
            <img src={system.src} alt={system.alt} loading="lazy" />
          </figure>
        )}
      </section>
    </section>

    <footer class="case-footer" aria-label="Project navigation">
      <div class="case-footer-meta">
        <p class="case-kicker">{client}</p>
        <p class="case-footer-year">{project.data.year}</p>
      </div>

      <a class="case-footer-link case-footer-link--prev" href={`/work/${previous.id}`}>
        Previous project
      </a>

      <span class="case-footer-counter" aria-label={`Project ${projectNumber}`}>[{projectNumber}]</span>

      <a class="case-footer-link case-footer-link--next" href={`/work/${next.id}`}>
        Next project
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .case-study {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
    min-height: 0;
  }

  .case-track {
    display: flex;
    height: 100%;
    min-height: 0;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    overscroll-behavior-x: contain;
  }

  .case-track::-webkit-scrollbar {
    display: none;
  }

  .case-panel {
    flex: 0 0 100%;
    min-width: 100%;
    height: 100%;
    padding: clamp(1rem, 1.6vw, 1.4rem) var(--pad) clamp(1.25rem, 2vw, 2rem);
    scroll-snap-align: start;
    display: grid;
    gap: clamp(1rem, 1.5vw, 1.5rem);
  }

  .case-panel--intro,
  .case-panel--system {
    grid-template-columns: minmax(18rem, 0.9fr) minmax(0, 1.6fr);
    align-items: center;
  }

  .case-panel--notes {
    grid-template-columns: minmax(17rem, 0.78fr) minmax(0, 1fr);
    align-items: start;
  }

  .case-copy,
  .case-panel-heading,
  .case-system-copy {
    display: grid;
    align-content: start;
    gap: 0.85rem;
    max-width: 36rem;
    padding-top: clamp(0.1rem, 0.5vw, 0.5rem);
  }

  .case-index {
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1;
  }

  .case-title {
    margin: 0;
    max-width: 11ch;
    font-family: var(--serif);
    font-size: clamp(3.75rem, 8.25vw, 8.5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 0.86;
    text-transform: uppercase;
  }

  .case-disciplines {
    margin: 0;
    max-width: 20ch;
    font-size: clamp(0.9rem, 1vw, 1.05rem);
    font-weight: 500;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .case-summary,
  .case-panel-copy,
  .case-notes :global(p) {
    margin: 0;
    max-width: 32rem;
    color: var(--muted);
    font-size: clamp(0.98rem, 1.25vw, 1.25rem);
    line-height: 1.38;
  }

  .case-meta {
    display: grid;
    gap: 0.2rem;
    margin-top: clamp(0.6rem, 1vw, 1rem);
  }

  .case-meta p,
  .case-details p {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    color: var(--muted);
    font-size: clamp(0.78rem, 0.92vw, 0.92rem);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .case-detail-label {
    color: var(--ink);
  }

  .case-notes {
    display: grid;
    gap: 1rem;
    max-width: 34rem;
  }

  .case-details {
    display: grid;
    gap: 0.45rem;
    padding-top: 0.35rem;
    border-top: 0.5px solid var(--line);
  }

  .case-figure {
    margin: 0;
    min-width: 0;
    align-self: center;
  }

  .case-figure img {
    width: 100%;
    height: min(100%, 78vh);
    max-height: calc(100dvh - 8.5rem);
    object-fit: cover;
    border: 0.5px solid var(--line);
    background: #f4f4f4;
  }

  .case-figure--hero img {
    min-height: 34rem;
  }

  .case-figure--detail img,
  .case-figure--system img {
    min-height: 24rem;
  }

  .case-panel--notes .case-figure--detail,
  .case-panel--system .case-figure--system {
    align-self: end;
  }

  .case-footer {
    display: grid;
    grid-template-columns: minmax(11rem, 1fr) minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: end;
    gap: 1rem;
    padding: 0.7rem var(--pad) 0.95rem;
    border-top: 0.5px solid var(--line);
  }

  .case-footer-meta {
    display: grid;
    gap: 0.1rem;
  }

  .case-footer-year {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .case-footer-link {
    align-self: center;
    color: var(--ink);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    font-weight: 500;
    text-decoration: none;
  }

  .case-footer-link--prev {
    justify-self: center;
  }

  .case-footer-link--next {
    justify-self: end;
  }

  .case-footer-counter {
    color: var(--muted);
    font-size: clamp(0.82rem, 0.95vw, 0.92rem);
    justify-self: center;
  }

  @media (hover: hover) {
    .case-footer-link:hover {
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }

    .case-figure img {
      transition: transform 320ms ease, box-shadow 320ms ease;
    }

    .case-panel:hover .case-figure img {
      transform: scale(1.01);
    }
  }

  @media (max-width: 920px) {
    .case-panel--intro,
    .case-panel--notes,
    .case-panel--system {
      grid-template-columns: 1fr;
      align-content: start;
    }

    .case-figure img {
      height: auto;
      min-height: 18rem;
      max-height: none;
      aspect-ratio: 4 / 3;
    }

    .case-footer {
      grid-template-columns: 1fr auto;
      row-gap: 0.5rem;
    }

    .case-footer-link--prev {
      justify-self: start;
    }

    .case-footer-link--next {
      justify-self: end;
    }

    .case-footer-counter {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .case-panel {
      padding-inline: var(--pad);
      padding-top: 0.85rem;
    }

    .case-title {
      font-size: clamp(3rem, 16vw, 5.5rem);
    }
  }
</style>
