---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectRows from '../components/ProjectRows.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="M. Hoffman | Creative Portfolio">
  <section class="home-hero page" aria-labelledby="home-title">
    <h1 id="home-title">M. Hoffman Creative Portfolio</h1>
    <img src="/images/website-large-5.gif" alt="" loading="eager" />
  </section>

  <section class="page intro section-grid" aria-labelledby="intro-title">
    <p id="intro-title" class="kicker">Approach</p>
    <p class="large-copy">Minimal structure for image-led stories, sharp typography, and patient case studies.</p>
  </section>

  <section class="page featured" aria-labelledby="featured-title">
    <p id="featured-title" class="kicker">Selected Work</p>
    <div class="featured-heading">
      <a href="/work">Index</a>
    </div>
    <ProjectRows projects={projects} showPreview />
  </section>
</BaseLayout>

<style>
  .home-hero {
    display: grid;
    min-height: calc(100svh - 3rem);
    align-items: end;
    padding: clamp(1.5rem, 4vw, 4rem) 0 clamp(2.5rem, 7vw, 7rem);
  }

  .home-hero h1 {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .home-hero img {
    width: 100%;
    max-height: min(78svh, 58rem);
    object-fit: cover;
  }

  .featured {
    padding: clamp(3rem, 8vw, 8rem) 0;
  }

  .featured-heading {
    display: flex;
    justify-content: right;
    gap: 1rem;
    align-items: baseline;
    width: min(100%, 1320px);
    margin: 0 auto clamp(0.65rem, 1.2vw, 1rem);
    padding: 0 clamp(1rem, 3vw, 4rem);
  }

  h2,
  .featured-heading a {
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.6rem, 0.68vw, 0.72rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .featured-heading a {
    text-decoration: none;
  }
</style>
