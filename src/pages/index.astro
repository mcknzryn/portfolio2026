---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
type ProjectEntry = CollectionEntry<'projects'>;

const getProjectPreviewStyle = (project: ProjectEntry) => {
  const width = project.data.homePreviewWidth;
  const lift = project.data.homePreviewLift;

  return [
    width ? `--photo-width: ${width};` : '',
    lift ? `--lift: ${lift};` : '',
  ]
    .filter(Boolean)
    .join(' ');
};
---

<BaseLayout title="McKenzie Hoffman">
  <section class="home page" aria-label="Selected projects">
    <ol class="project-index" aria-label="Project index">
      {projects.map((project, index) => {
        const number = String(project.data.order + 1).padStart(2, '0');

        return (
          <li class:list={['project-item', `project-item-${index + 1}`]} style={getProjectPreviewStyle(project)}>
            <a class="project-link" href={`/work/${project.id}`} aria-label={`${number} ${project.data.title}`}>
              <span class="project-number" aria-hidden="true">
                {number}
              </span>
              <span class="project-image">
                <img src={project.data.heroImage} alt={project.data.title} loading={index === 0 ? 'eager' : 'lazy'} />
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>
</BaseLayout>

<style>
  .home {
    display: grid;
    min-height: calc(100svh - 3rem);
    align-content: center;
    gap: clamp(2.5rem, 7vw, 6rem);
    padding: clamp(1.5rem, 3vw, 2.25rem) 0 clamp(1.5rem, 3vw, 2.25rem);
  }

  .project-index {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: clamp(12.5rem, 15vw, 17rem);
    align-items: end;
    gap: clamp(1.5rem, 4vw, 4rem) clamp(1.5rem, 3vw, 3rem);
    margin: 0;
    padding: 0 clamp(1.25rem, 4vw, 4.5rem);
    list-style: none;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    scroll-padding-inline: clamp(1.25rem, 4vw, 4.5rem);
    margin-top: clamp(-10rem, -12vh, -10rem);
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .project-index::-webkit-scrollbar {
    display: none;
  }

  .project-item {
    --lift: 0px;
    --photo-width: clamp(9rem, 12vw, 13rem);
    scroll-snap-align: start;
  }

  .project-link {
    display: grid;
    gap: 0.45rem;
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
    text-decoration: none;
    transform: translateY(var(--lift));
  }

  .project-number {
    font-size: clamp(0.72rem, 0.85vw, 0.85rem);
    line-height: 1;
    font-weight: 500;
  }

  .project-image {
    display: block;
    width: min(100%, var(--photo-width));
  }

  .project-image img {
    width: 100%;
    height: auto;
    object-fit: initial;
    transition: opacity 220ms ease;
    opacity: 1;
  }

  @media (hover: hover) {
    .project-link:hover .project-image img,
    .project-link:focus-visible .project-image img {
      opacity: 0.8;
    }
  }

  @media (max-width: 980px) {
    .home {
      align-content: start;
    }

    .project-index {
      grid-auto-columns: clamp(11.5rem, 30vw, 14.5rem);
      margin-top: 0;
      gap: clamp(1.25rem, 3.5vw, 3rem) clamp(1.25rem, 2.5vw, 2rem);
      padding-inline: clamp(0.9rem, 2.5vw, 2rem);
      scroll-padding-inline: clamp(0.9rem, 2.5vw, 2rem);
    }
  }

  @media (max-width: 640px) {
    .project-index {
      grid-auto-columns: clamp(10rem, 68vw, 12.5rem);
      gap: 1rem;
      padding-inline: 0.9rem;
      scroll-padding-inline: 0.9rem;
    }

    .project-link {
      width: min(100%, 14.5rem);
    }

    .project-image {
      width: 100%;
    }
  }
</style>
