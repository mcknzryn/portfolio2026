---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="M. Hoffman | Creative Portfolio">
  <section class="home page" aria-labelledby="home-title">
    <h1 id="home-title" class="sr-only">Selected projects</h1>

    <ol class="project-index" aria-label="Project index">
      {projects.map((project, index) => {
        const number = String(project.data.order + 1).padStart(2, '0');

        return (
          <li class:list={['project-item', `project-item-${index + 1}`]}>
            <a class="project-link" href={`/work/${project.id}`} aria-label={`${number} ${project.data.title}`}>
              <span class="project-number" aria-hidden="true">
                {number}
              </span>
              <span class="project-image">
                <img src={project.data.heroImage} alt={project.data.title} loading={index === 0 ? 'eager' : 'lazy'} />
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>
</BaseLayout>

<style>
  .home {
    display: grid;
    min-height: calc(100svh - 3rem);
    align-content: space-between;
    gap: clamp(2rem, 6vw, 5rem);
    padding: clamp(1.5rem, 3vw, 2.25rem) 0 clamp(1.5rem, 3vw, 2.25rem);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .project-index {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 3rem) clamp(1rem, 2vw, 2rem);
    margin: 0;
    padding: 0;
    list-style: none;
    align-items: end;
  }

  .project-item {
    --lift: 0px;
  }

  .project-item:nth-child(2n) {
    --lift: clamp(0.75rem, 4vw, 3rem);
  }

  .project-item:nth-child(3n) {
    --lift: clamp(0.25rem, 2.2vw, 1.5rem);
  }

  .project-link {
    display: grid;
    gap: 0.45rem;
    width: min(100%, 16rem);
    margin-inline: auto;
    text-decoration: none;
    transform: translateY(var(--lift));
  }

  .project-number {
    font-size: clamp(0.72rem, 0.85vw, 0.85rem);
    line-height: 1;
    font-weight: 500;
  }

  .project-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f2f2f2;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  @media (hover: hover) {
    .project-link:hover .project-image img,
    .project-link:focus-visible .project-image img {
      transform: scale(1.02);
    }
  }

  @media (max-width: 980px) {
    .project-index {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-link {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .project-index {
      grid-template-columns: 1fr;
    }

    .project-link {
      width: min(100%, 22rem);
    }
  }
</style>
