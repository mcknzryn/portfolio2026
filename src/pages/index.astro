---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
type ProjectEntry = CollectionEntry<'projects'>;

const getProjectPreviewStyle = (project: ProjectEntry) => {
  const width = project.data.homePreviewWidth;
  const lift = project.data.homePreviewLift;

  return [
    width ? `--photo-width: ${width};` : '',
    lift ? `--lift: ${lift};` : '',
  ]
    .filter(Boolean)
    .join(' ');
};
---

<BaseLayout title="McKenzie Hoffman">
  <section class="home page" aria-label="Selected projects">

    <ol class="project-index" aria-label="Project index">
      {projects.map((project, index) => {
        const number = String(project.data.order + 1).padStart(2, '0');

        return (
          <li class:list={['project-item', `project-item-${index + 1}`]} style={getProjectPreviewStyle(project)}>
            <a class="project-link" href={`/work/${project.id}`} aria-label={`${number} ${project.data.title}`}>
              <span class="project-number" aria-hidden="true">
                {number}
              </span>
              <span class="project-image">
                <img src={project.data.heroImage} alt={project.data.title} loading={index === 0 ? 'eager' : 'lazy'} />
              </span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>
</BaseLayout>

<style>
  .home {
    display: grid;
    min-height: calc(100svh - 3rem);
    align-content: center;
    gap: clamp(2rem, 6vw, 5rem);
    padding: clamp(1.5rem, 3vw, 2.25rem) 0 clamp(1.5rem, 3vw, 2.25rem);
  }

  .project-index {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    row-gap: 0;
    column-gap: clamp(1rem, 2vw, 2rem);
    margin: clamp(-10rem, -12vh, -10rem) 0 0;
    padding: 0 0 0 clamp(1rem, 3vw, 3.5rem);
    list-style: none;
    align-items: end;
  }

  .project-item {
    --lift: 0px;
    --photo-width: clamp(11.5rem, 16vw, 16rem);
  }

  .project-link {
    display: grid;
    gap: 0.45rem;
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
    text-decoration: none;
    transform: translateY(var(--lift));
  }

  .project-number {
    font-size: clamp(0.72rem, 0.85vw, 0.85rem);
    line-height: 1;
    font-weight: 500;
  }

  .project-image {
    display: block;
    width: min(100%, var(--photo-width));
  }

  .project-image img {
    width: 100%;
    height: auto;
    object-fit: initial;
    transition: opacity 220ms ease;
    opacity: 1;
  }

  @media (hover: hover) {
    .project-link:hover .project-image img,
    .project-link:focus-visible .project-image img {
      opacity: 0.8;
    }
  }

  @media (max-width: 980px) {
    .home {
      align-content: start;
    }

    .project-index {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: 0;
      margin-top: 0;
      padding-left: clamp(0.75rem, 2vw, 1.5rem);
    }

    .project-link {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .project-index {
      grid-template-columns: 1fr;
      padding-left: 0;
    }

    .project-link {
      width: min(100%, 22rem);
    }

    .project-image {
      width: 100%;
    }
  }
</style>
