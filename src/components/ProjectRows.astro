---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
  showPreview?: boolean;
}

const { projects, showPreview = false } = Astro.props;
---

<div class="project-rows">
  {projects.map((project) => (
    <a class:list={['project-row', showPreview && 'has-preview']} href={`/work/${project.id}`}>
      <span class="project-row-main">
        <span class="project-title">{project.data.title}</span>
        <span class="project-meta">{project.data.discipline.join(', ')}</span>
        <span class="project-year">{project.data.year}</span>
      </span>

      {showPreview && (
        <span class="project-preview" aria-hidden={!showPreview}>
          <span class="project-summary">{project.data.summary}</span>
          <span class="project-thumbs">
            {project.data.images.slice(0, 3).map((image) => (
              <span class="project-thumb">
                <img src={image.src} alt={image.alt} loading="lazy" />
              </span>
            ))}
          </span>
        </span>
      )}
    </a>
  ))}
</div>

<style>
  .project-rows {
    border-top: 0.5px solid var(--line);
  }

  .project-row {
    display: block;
    min-height: clamp(5rem, 10vw, 8rem);
    padding: 1.15rem 0;
    border-bottom: 0.5px solid var(--line);
    text-decoration: none;
  }

  .project-row-main {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(12rem, 0.8fr) 5rem;
    gap: clamp(1rem, 3vw, 3rem);
    align-items: baseline;
  }

  .project-title {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 8vw, 8rem);
    line-height: 0.9;
  }

  .project-meta,
  .project-year {
    color: var(--muted);
    font-size: clamp(0.76rem, 1vw, 0.95rem);
    text-transform: uppercase;
  }

  .project-year {
    text-align: right;
  }

  .project-preview {
    display: grid;
    grid-template-columns: minmax(12rem, 0.55fr) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 3rem);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-0.4rem);
    transition:
      max-height 360ms ease,
      opacity 240ms ease,
      transform 240ms ease,
      padding-top 240ms ease;
  }

  .project-summary {
    max-width: 31rem;
    color: var(--muted);
    font-size: clamp(0.95rem, 1.45vw, 1.45rem);
    line-height: 1.3;
  }

  .project-thumbs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.55rem, 1vw, 1rem);
  }

  .project-thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 0.5px solid var(--line);
    background: #f4f4f4;
  }

  .project-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms ease;
  }

  @media (hover: hover) {
    .project-row:hover .project-title {
      font-style: italic;
    }

    .project-row.has-preview:hover .project-preview,
    .project-row.has-preview:focus-visible .project-preview {
      max-height: clamp(12rem, 24vw, 26rem);
      padding-top: clamp(0.9rem, 1.8vw, 1.6rem);
      opacity: 1;
      transform: translateY(0);
    }

    .project-row.has-preview:hover .project-thumb img,
    .project-row.has-preview:focus-visible .project-thumb img {
      transform: scale(1.03);
    }
  }

  @media (max-width: 760px) {
    .project-row-main,
    .project-preview {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    .project-row {
      min-height: 0;
    }

    .project-year {
      text-align: left;
    }

    .project-preview {
      max-height: none;
      padding-top: 0.85rem;
      opacity: 1;
      transform: none;
    }

    .project-thumbs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-thumb:nth-child(3) {
      display: none;
    }
  }
</style>
