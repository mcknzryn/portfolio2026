---
import type { CollectionEntry } from 'astro:content';
import { formatProjectNumber } from '../lib/formatProjectNumber';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<div class="project-rows">
  {projects.map((project) => (
    <a class="project-row" href={`/work/${project.id}`}>
      <span class="project-row-main">
        <span class="project-number">{`[${formatProjectNumber(project.data.order)}]`}</span>
        <span class="project-year">{project.data.year}</span>
        <span class="project-title">{project.data.title}</span>
        <span class="project-meta">{project.data.discipline.join(', ')}</span>
      </span>
      <span class="project-gallery" aria-hidden="true">
        {project.data.images.slice(0, 3).map((image) => (
          <span class="project-shot">
            <img src={image.src} alt="" loading="lazy" />
          </span>
        ))}
      </span>
    </a>
  ))}
</div>

<style>
  .project-rows {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    width: min(100%, 1320px);
    margin: 0 auto;
    padding: 0 clamp(1rem, 3vw, 4rem);
  }

  .project-row {
    display: grid;
    gap: clamp(0.9rem, 1.8vw, 1.5rem);
    min-height: 0;
    padding: 0;
    text-decoration: none;
  }

  .project-row-main {
    display: grid;
    grid-template-columns: 3.75rem 4.5rem minmax(0, 1.7fr) minmax(12rem, 0.95fr);
    gap: clamp(1rem, 2.2vw, 2.75rem);
    align-items: baseline;
  }

  .project-title {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.6vw, 1.8rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .project-meta,
  .project-year,
  .project-number {
    color: var(--muted);
    font-size: clamp(0.7rem, 0.85vw, 0.86rem);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .project-year {
    text-align: left;
  }

  .project-number {
    color: var(--muted);
    font-size: clamp(0.6rem, 0.68vw, 0.72rem);
  }

  .project-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.5rem, 1vw, 0.9rem);
  }

  .project-shot {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f3f3f3;
  }

  .project-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms ease, opacity 220ms ease;
  }

  @media (hover: hover) {
    .project-row:hover .project-title {
      font-style: italic;
    }

    .project-row:hover .project-shot img,
    .project-row:focus-visible .project-shot img {
      transform: scale(1.03);
      opacity: 0.9;
    }
  }

  @media (max-width: 760px) {
    .project-row-main {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .project-row {
      min-height: 0;
    }

    .project-gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-shot:nth-child(3) {
      display: none;
    }
  }
</style>
