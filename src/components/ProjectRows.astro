---
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
  showPreview?: boolean;
}

const { projects, showPreview = false } = Astro.props;
---

<div class="project-rows">
  {projects.map((project) => (
    <a class:list={['project-row', showPreview && 'home-preview']} href={`/work/${project.id}`}>
      {showPreview ? (
        <>
          <span class="project-number">{`[${String(project.data.order + 1).padStart(2, '0')}]`}</span>
          <span class="project-feature">
            <span class="project-title">{project.data.title}</span>
            <span class="project-thumbs">
              {project.data.images.slice(0, 3).map((image) => (
                <span class="project-thumb">
                  <img src={image.src} alt={image.alt} loading="lazy" />
                </span>
              ))}
            </span>
          </span>
          <span class="project-meta-group">
            <span>{project.data.discipline.join(', ')}</span>
            <span>{project.data.year}</span>
          </span>
          <span class="project-summary">{project.data.summary}</span>
          <span class="project-client">{project.data.client}</span>
        </>
      ) : (
        <>
          <span class="project-row-main">
            <span class="project-number">{`[${String(project.data.order + 1).padStart(2, '0')}]`}</span>
            <span class="project-year">{project.data.year}</span>
            <span class="project-title">{project.data.title}</span>
            <span class="project-meta">{project.data.discipline.join(', ')}</span>
          </span>
          <span class="project-gallery" aria-hidden="true">
            {project.data.images.slice(0, 3).map((image) => (
              <span class="project-shot">
                <img src={image.src} alt="" loading="lazy" />
              </span>
            ))}
          </span>
        </>
      )}
    </a>
  ))}
</div>

<style>
  .project-rows {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    width: min(100%, 1320px);
    margin: 0 auto;
    padding: 0 clamp(1rem, 3vw, 4rem);
  }

  .project-row {
    display: grid;
    gap: clamp(0.9rem, 1.8vw, 1.5rem);
    min-height: 0;
    padding: 0;
    text-decoration: none;
  }

  .project-row.home-preview {
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr) minmax(12rem, 0.36fr);
    gap: clamp(0.65rem, 1.7vw, 1.8rem);
    align-items: baseline;
    min-height: 0;
    padding: clamp(0.55rem, 0.9vw, 1rem) 0;
    border-bottom: 0.5px solid var(--line);
    transition: opacity 180ms ease;
  }

  .project-row-main {
    display: grid;
    grid-template-columns: 3.75rem 4.5rem minmax(0, 1.7fr) minmax(12rem, 0.95fr);
    gap: clamp(1rem, 2.2vw, 2.75rem);
    align-items: baseline;
  }

  .project-title {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 1.6vw, 1.8rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .home-preview .project-title {
    display: block;
    min-width: min(100%, 10.5rem);
    font-size: clamp(1.15rem, 1.65vw, 2.15rem);
    line-height: 1.02;
  }

  .project-meta,
  .project-year,
  .project-number {
    color: var(--muted);
    font-size: clamp(0.7rem, 0.85vw, 0.86rem);
    line-height: 1.35;
    text-transform: uppercase;
  }

  .project-year {
    text-align: left;
  }

  .project-number {
    color: var(--muted);
    font-size: clamp(0.6rem, 0.68vw, 0.72rem);
  }

  .project-feature {
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 2vw, 2.35rem);
    min-width: 0;
  }

  .project-thumbs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.3rem, 0.55vw, 0.55rem);
    width: min(30vw, 24rem);
    min-width: 12rem;
  }

  .project-thumb {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f4f4f4;
  }

  .project-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms ease;
  }

  .project-meta-group {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 4rem 1rem;
    gap: clamp(0.55rem, 1vw, 1.1rem);
    align-items: baseline;
    color: var(--muted);
    font-size: clamp(0.6rem, 0.68vw, 0.72rem);
    line-height: 1.4;
    text-transform: uppercase;
  }

  .project-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.5rem, 1vw, 0.9rem);
  }

  .project-shot {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f3f3f3;
  }

  .project-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms ease, opacity 220ms ease;
  }

  .project-summary,
  .project-client {
    grid-column: 2 / -1;
    max-width: 45rem;
    color: var(--muted);
    font-size: clamp(0.76rem, 0.85vw, 0.9rem);
    line-height: 1.35;
  }

  .project-summary {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-0.3rem);
    transition:
      max-height 260ms ease,
      opacity 180ms ease,
      transform 180ms ease,
      margin-top 180ms ease;
  }

  .project-client {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    font-size: clamp(0.6rem, 0.68vw, 0.72rem);
    text-transform: uppercase;
    transform: translateY(-0.3rem);
    transition:
      max-height 260ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  @media (hover: hover) {
    .project-rows:has(.home-preview:hover) .home-preview:not(:hover),
    .project-rows:has(.home-preview:focus-visible) .home-preview:not(:focus-visible) {
      opacity: 0.36;
    }

    .project-row:hover .project-title {
      font-style: italic;
    }

    .project-row.home-preview:hover .project-summary,
    .project-row.home-preview:focus-visible .project-summary,
    .project-row.home-preview:hover .project-client,
    .project-row.home-preview:focus-visible .project-client {
      max-height: 5rem;
      opacity: 1;
      transform: translateY(0);
    }

    .project-row.home-preview:hover .project-summary,
    .project-row.home-preview:focus-visible .project-summary {
      margin-top: clamp(0.35rem, 0.65vw, 0.65rem);
    }

    .project-row.home-preview:hover .project-thumb img,
    .project-row.home-preview:focus-visible .project-thumb img {
      transform: scale(1.03);
    }

    .project-row:hover .project-shot img,
    .project-row:focus-visible .project-shot img {
      transform: scale(1.03);
      opacity: 0.9;
    }
  }

  @media (max-width: 760px) {
    .project-row-main,
    .project-row.home-preview {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .project-row {
      min-height: 0;
    }

    .project-feature {
      display: grid;
      gap: 1rem;
    }

    .project-thumbs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
      min-width: 0;
    }

    .project-thumb:nth-child(3) {
      display: none;
    }

    .project-meta-group {
      grid-template-columns: 1fr auto;
    }

    .project-meta-group span:nth-child(2) {
      text-align: right;
    }

    .project-gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-shot:nth-child(3) {
      display: none;
    }

    .project-summary,
    .project-client {
      grid-column: auto;
    }

    .project-summary {
      max-height: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
